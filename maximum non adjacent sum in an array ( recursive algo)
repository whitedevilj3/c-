#include<stdio.h>
int max(int n,int m){
    if(n>m){
        return n;
    }
    return m;
}
int mnas(int n,int a[],int i){
    int include = 0;
    int exclude = 0;
    if(i >= n){
        return 0;
    }
    include = mnas(n,a,i+2)+a[i];
    exclude = mnas(n,a,i+1)+0;
    return max(include,exclude);
}
int main(){
    int n;
    scanf("%d",&n);
    int a[n];
    for(int i = 0;i<n;i++){
        scanf("%d",&a[i]);
    }
    int max = mnas(n,a,0);
    printf("%d\n",max);
    return 0;
}
