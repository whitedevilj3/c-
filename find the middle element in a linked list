#include<stdio.h>
#include<stdlib.h>
struct node{
    int data;
    struct node* next;
};
struct node* nnode(int val){
    struct node* n = (struct node*)malloc(sizeof(struct node));
    n->data =val;
    n->next = NULL;
    return n ;
}
struct node* createlist(int n){
    struct node* head = NULL;
    struct node* tail = NULL;
    for(int i = 0;i<n;i++){
        int data;
        scanf("%d",&data);
        struct node* n = nnode(data);
        if(head == NULL){
            head = n;
            tail = n;
        }
        else{
            tail->next = n;
            tail = n;
        }
    }
    return head;
}
void pme(int n,struct node* head){
    struct node* temp = head;
    int count = 0;
    while(count != n/2 && temp != NULL){
        count++;
        temp = temp->next;
    }
    printf("%d\n",temp->data);
}

int main(){
    int n;
    scanf("%d",&n);
    struct node* nnode = createlist(n);
    pme(n,nnode);
    return 0;
}
