#include<stdio.h>
#include<stdlib.h>
struct node{
    int data;
    struct node* next;
};
struct node* nnode(int val){
    struct node* n = (struct node*)malloc(sizeof(struct node));
    n->data = val;
    n->next = NULL;
    return n;
}
struct node* createList(struct node* head,int n){
    struct node* tail = head;
    for(int i = 0;i<n;i++){
        int val;
        scanf("%d",&val);
        struct node* nn = nnode(val);
        if(head == NULL ){
            head = nn;
            tail = nn;
        }
        else{
            tail->next = nn;
            tail = tail->next;
        }
    }
    return head;
}
