    while(temp1 != NULL){
        temp1 = temp1->next;
        count1++;
    }
    while(temp2 != NULL){
        temp2 = temp2->next;
        count2++;
    }
    temp1 = head1;
    temp2 = head2;
    if(count1>count2){
        int n = count1-count2;
        int p = 0;
        while(p<n){
            temp1 = temp1->next;
            p++
        }
        while(temp1 != NULL && temp2 != NULL){
            if(temp1 == temp2){
                return 1;
            }
            temp1 = temp1->next;
            temp2 = temp2->next;
        } 
        
    }
    else{
        int n = count2-count1;
        int p = 0;
        while(p<n){
            temp2 = temp2->next;
            p++
        }
        while(temp1 != NULL && temp2 != NULL){
            if(temp1 == temp2){
                return 1;
            }
            temp1 = temp1->next;
            temp2 = temp2->next;
        } 
    }
    return 0;
}
